From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
Subject: [PATCH] Use native cli-arm64.exe for win-arm64

Upstream 26.x maps launcher stubs via WINDOWS_LAUNCHER_STUB_PATH; win-arm64
still pointed at cli-64.exe. Point it at shell/cli-arm64.exe (shipped beside
the recipe via build/script).

---
 conda/base/constants.py | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/conda/base/constants.py b/conda/base/constants.py
index 2244a1a..eb2704e 100644
--- a/conda/base/constants.py
+++ b/conda/base/constants.py
@@ -112,8 +112,7 @@ PLATFORM_DIRECTORIES = KNOWN_SUBDIRS
 WINDOWS_LAUNCHER_STUB_PATH: Final = {
     "win-32": "shell/cli-32.exe",
     "win-64": "shell/cli-64.exe",
-    "win-arm64": "shell/cli-64.exe",  # rely on arm64 emulation for now
-    # "win-arm64": "shell/cli-arm64.exe",  # add native arm64 support when available
+    "win-arm64": "shell/cli-arm64.exe",
 }
 
 RECOGNIZED_URL_SCHEMES: Final = ("http", "https", "ftp", "s3", "file")
